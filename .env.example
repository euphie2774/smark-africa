# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourSecurePassword123!
ADMIN_EMAIL=admin@smarkafrica.com

# M-Pesa Daraja API
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_PASSKEY=
DARAJA_SHORTCODE=174379
DARAJA_ENV=sandbox

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_ENV=sandbox

# Resend (email)
# Get your API key from https://resend.com/api-keys
# By default emails are sent from onboarding@resend.dev (Resend test domain)
# To use your own domain, verify it at https://resend.com/domains
# and set from_email in admin settings to your verified domain
RESEND_API_KEY=

# Africa's Talking (SMS)
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

# Mail (SMTP fallback)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Optional
REDIS_URL=
DATABASE_URL=
OPENAI_API_KEY=
